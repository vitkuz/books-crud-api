{
  "name": "books-crud-api",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal Books CRUD REST API (TypeScript + Express, in-memory storage).",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:integration:local": "ts-node tests/integration/run-local.ts",
    "test:integration:deploy": "ts-node tests/integration/run-deploy.ts",
    "test:integration:dynamodb": "ts-node tests/integration/run-dynamodb.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1037.0",
    "@aws-sdk/lib-dynamodb": "^3.1037.0",
    "@codegenie/serverless-express": "^5.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/uuid": "^9.0.8",
    "axios": "^1.15.2",
    "esbuild": "^0.28.0",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
